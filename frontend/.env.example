# Frontend Environment Configuration for Development
# Copy this file to .env and fill in your actual values

# API Configuration
CC_BASE_URL_WEB=http://localhost:8080
CC_BASE_URL_ANDROID=http://10.0.2.2:8080
CC_BASE_URL_OTHER=http://localhost:8080

# Sentiment capture mode for live calls
# balanced = lower Bedrock/API traffic (default)
# realtime = faster updates, higher traffic/cost
# adaptive = auto-switch between realtime and balanced based on runtime pressure
CC_SENTIMENT_MODE=balanced

# Google Places API (for address autocomplete)
# Get API key from Google Cloud Console: https://console.cloud.google.com/
# Enable: Places API, Maps SDK for Android, Maps SDK for iOS
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# AI Service Configuration
# Get API keys from respective providers
OPENAI_API_KEY=your_openai_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
deepSeek_uri=https://api.deepseek.com/v1/chat/completions

# Authentication
# Generate secure JWT secret (at least 32 characters)
JWT_SECRET=your_jwt_secret_key_here
CC_BACKEND_TOKEN=your_backend_token_here

# Apple Pay Configuration
APPLE_MERCHANT_ID=com.lauh.careconnect

# Google Pay Configuration
GOOGLE_PAY_MERCHANT_ID=BCR2DN5TS3O2BIBM

#MailDigestConfiguration
GOOGLE_CLIENT_ID=your-id
GOOGLE_CLIENT_SECRET=your-secret
MS_CLIENT_ID=your-ms-id
MS_CLIENT_SECRET=your-ms-secret
