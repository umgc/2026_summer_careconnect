          "sourceMapping": { "documentField": "Felony conviction question", "line": "Q1", "page": 1 } },
        { "id": "convicted_misdemeanor", "label": "Have you ever been convicted of a misdemeanor involving violence, theft, fraud, or abuse?", "fieldType": "RADIO", "required": true, "order": 1,
