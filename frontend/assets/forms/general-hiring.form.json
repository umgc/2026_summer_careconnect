{
  "formType": "GENERAL_HIRING",
  "title": "General Employment Application",
  "description": "General hiring application capturing applicant contact details, position, availability, employment history, and references.",
  "issuingAuthority": "CareConnect HR",
  "version": "1.0.0",
  "effectiveDate": "2026-01-01",
  "sourceDocument": {
    "name": "Employment Application",
    "formNumber": "HR-EA-01",
