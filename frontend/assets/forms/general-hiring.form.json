  },
  "fileAttachment": {
    "category": "HIRING_DOCUMENT",
    "generatesPdf": true,
    "supportingDocumentCategories": ["HIRING_DOCUMENT", "OTHER_DOCUMENT"]
  },
  "sections": [
    {
      "id": "contact",
      "title": "Applicant Contact Information",
      "order": 0,
      "required": true,
      "completedBy": "EMPLOYEE",
      "fields": [
        { "id": "first_name", "label": "First name", "fieldType": "TEXT", "required": true, "order": 0,
          "sourceMapping": { "documentField": "First Name", "page": 1 } },
        { "id": "last_name", "label": "Last name", "fieldType": "TEXT", "required": true, "order": 1,
          "sourceMapping": { "documentField": "Last Name", "page": 1 } },
        { "id": "email", "label": "Email address", "fieldType": "EMAIL", "required": true, "order": 2,
          "validations": [{ "type": "EMAIL" }],
          "sourceMapping": { "documentField": "Email", "page": 1 } },
        { "id": "phone", "label": "Phone number", "fieldType": "PHONE", "required": true, "order": 3,
          "sourceMapping": { "documentField": "Phone", "page": 1 } },
        { "id": "address", "label": "Street address", "fieldType": "TEXT", "required": true, "order": 4,
          "sourceMapping": { "documentField": "Address", "page": 1 } },
        { "id": "city", "label": "City", "fieldType": "TEXT", "required": true, "order": 5,
          "sourceMapping": { "documentField": "City", "page": 1 } },
        { "id": "state", "label": "State", "fieldType": "STATE", "required": true, "order": 6,
          "sourceMapping": { "documentField": "State", "page": 1 } },
        { "id": "zip", "label": "ZIP code", "fieldType": "ZIP", "required": true, "order": 7,
          "validations": [{ "type": "PATTERN", "pattern": "^\\d{5}(-\\d{4})?$" }],
          "sourceMapping": { "documentField": "ZIP", "page": 1 } }
      ]
    },
    {
      "id": "position",
      "title": "Position and Availability",
      "order": 1,
      "required": true,
      "completedBy": "EMPLOYEE",
      "fields": [
        { "id": "position_applied", "label": "Position applied for", "fieldType": "TEXT", "required": true, "order": 0,
          "sourceMapping": { "documentField": "Position Applied For", "page": 1 } },
        { "id": "employment_type", "label": "Desired employment type", "fieldType": "SELECT", "required": true, "order": 1,
          "options": [
            { "value": "FULL_TIME", "label": "Full-time" },
            { "value": "PART_TIME", "label": "Part-time" },
            { "value": "PER_DIEM", "label": "Per diem" }
          ],
          "validations": [{ "type": "ENUM", "value": ["FULL_TIME", "PART_TIME", "PER_DIEM"] }],
          "sourceMapping": { "documentField": "Employment Type", "page": 1 } },
        { "id": "available_start_date", "label": "Available start date", "fieldType": "DATE", "required": true, "order": 2,
          "validations": [{ "type": "DATE" }],
          "sourceMapping": { "documentField": "Available Start Date", "page": 1 } },
        { "id": "legally_authorized", "label": "Are you legally authorized to work in the U.S.?", "fieldType": "RADIO", "required": true, "order": 3,
          "options": [ { "value": "YES", "label": "Yes" }, { "value": "NO", "label": "No" } ],
          "validations": [{ "type": "ENUM", "value": ["YES", "NO"] }],
          "sourceMapping": { "documentField": "Authorized to work", "page": 1 } }
      ]
    },
    {
      "id": "employment_history",
      "title": "Employment History",
      "order": 2,
      "required": false,
      "repeatable": true,
      "completedBy": "EMPLOYEE",
      "fields": [
        { "id": "employer_name", "label": "Employer name", "fieldType": "TEXT", "required": false, "order": 0,
          "sourceMapping": { "documentField": "Employer", "page": 1 } },
        { "id": "job_title", "label": "Job title", "fieldType": "TEXT", "required": false, "order": 1,
          "sourceMapping": { "documentField": "Job Title", "page": 1 } },
        { "id": "start_date", "label": "Start date", "fieldType": "DATE", "required": false, "order": 2,
          "sourceMapping": { "documentField": "From", "page": 1 } },
        { "id": "end_date", "label": "End date", "fieldType": "DATE", "required": false, "order": 3,
          "sourceMapping": { "documentField": "To", "page": 1 } },
        { "id": "reason_leaving", "label": "Reason for leaving", "fieldType": "TEXT", "required": false, "order": 4,
          "sourceMapping": { "documentField": "Reason for Leaving", "page": 1 } }
      ]
    },
    {
      "id": "references",
      "title": "Professional References",
      "order": 3,
      "required": false,
      "repeatable": true,
      "completedBy": "EMPLOYEE",
      "fields": [
        { "id": "reference_name", "label": "Reference name", "fieldType": "TEXT", "required": false, "order": 0,
          "sourceMapping": { "documentField": "Reference Name", "page": 2 } },
        { "id": "reference_relationship", "label": "Relationship", "fieldType": "TEXT", "required": false, "order": 1,
          "sourceMapping": { "documentField": "Relationship", "page": 2 } },
        { "id": "reference_phone", "label": "Reference phone", "fieldType": "PHONE", "required": false, "order": 2,
          "sourceMapping": { "documentField": "Reference Phone", "page": 2 } }
      ]
    },
    {
      "id": "certification",
      "title": "Applicant Certification",
      "order": 4,
      "required": true,
      "completedBy": "EMPLOYEE",
      "fields": [
        { "id": "certify_true", "label": "I certify that the information provided is true and complete", "fieldType": "CHECKBOX", "required": true, "order": 0,
          "validations": [{ "type": "CHECKED" }],
          "sourceMapping": { "documentField": "Certification statement", "page": 2 } },
        { "id": "signature", "label": "Applicant signature", "fieldType": "SIGNATURE", "required": true, "order": 1,
          "validations": [{ "type": "REQUIRED" }],
          "sourceMapping": { "documentField": "Signature", "page": 2 } },
        { "id": "signature_date", "label": "Date", "fieldType": "DATE", "required": true, "order": 2,
          "validations": [{ "type": "DATE" }],
          "sourceMapping": { "documentField": "Date", "page": 2 } }
      ]
    }
  ]
}
