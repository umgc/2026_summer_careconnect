          "sourceMapping": { "documentField": "ZIP Code", "section": "Section 1", "page": 1 } },
        { "id": "date_of_birth", "label": "Date of birth", "fieldType": "DATE", "required": true, "order": 9, "sensitive": true,
          "validations": [{ "type": "DATE" }, { "type": "AGE_MIN", "value": 14, "message": "Employee must meet minimum working age." }],
          "sourceMapping": { "documentField": "Date of Birth (mm/dd/yyyy)", "section": "Section 1", "page": 1 } },
        { "id": "ssn", "label": "U.S. Social Security Number", "fieldType": "SSN", "required": false, "order": 10, "sensitive": true,
          "helpText": "Required only if the employer participates in E-Verify.",
          "validations": [{ "type": "SSN" }],
          "sourceMapping": { "documentField": "U.S. Social Security Number", "section": "Section 1", "page": 1 } },
        { "id": "email", "label": "Employee's email address", "fieldType": "EMAIL", "required": false, "order": 11,
          "validations": [{ "type": "EMAIL" }],
          "sourceMapping": { "documentField": "Employee's Email Address", "section": "Section 1", "page": 1 } },
        { "id": "phone", "label": "Employee's telephone number", "fieldType": "PHONE", "required": false, "order": 12,
