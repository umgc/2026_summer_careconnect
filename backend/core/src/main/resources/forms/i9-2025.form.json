        { "id": "middle_initial", "label": "Middle initial", "fieldType": "TEXT", "required": false, "order": 2,
          "validations": [{ "type": "MAX_LENGTH", "value": 1 }],
          "sourceMapping": { "documentField": "Middle Initial", "section": "Section 1", "page": 1 } },
        { "id": "other_last_names", "label": "Other last names used (if any)", "fieldType": "TEXT", "required": false, "order": 3,
          "sourceMapping": { "documentField": "Other Last Names Used", "section": "Section 1", "page": 1 } },
        { "id": "address_street", "label": "Address (Street number and name)", "fieldType": "TEXT", "required": true, "order": 4,
