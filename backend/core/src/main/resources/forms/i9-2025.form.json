        { "id": "citizenship_status", "label": "Citizenship / immigration status attestation", "fieldType": "RADIO", "required": true, "order": 13,
          "options": [
            { "value": "US_CITIZEN", "label": "A citizen of the United States" },
            { "value": "NONCITIZEN_NATIONAL", "label": "A noncitizen national of the United States" },
            { "value": "LPR", "label": "A lawful permanent resident" },
            { "value": "ALIEN_AUTHORIZED", "label": "An alien authorized to work" }
          ],
          "validations": [{ "type": "ENUM", "value": ["US_CITIZEN", "NONCITIZEN_NATIONAL", "LPR", "ALIEN_AUTHORIZED"] }],
          "sourceMapping": { "documentField": "Citizenship/Immigration Status (Boxes 1-4)", "section": "Section 1", "line": "Box 1-4", "page": 1 } },
        { "id": "lpr_uscis_number", "label": "USCIS/A-Number (lawful permanent resident)", "fieldType": "TEXT", "required": false, "order": 14, "sensitive": true,
          "visibleWhen": { "fieldId": "citizenship_status", "equals": "LPR" },
          "sourceMapping": { "documentField": "USCIS Number / A-Number", "section": "Section 1", "line": "Box 3", "page": 1 } },
        { "id": "alien_work_until", "label": "Authorized to work until (expiration date, if any)", "fieldType": "DATE", "required": false, "order": 15,
          "visibleWhen": { "fieldId": "citizenship_status", "equals": "ALIEN_AUTHORIZED" },
          "sourceMapping": { "documentField": "Authorized to work until", "section": "Section 1", "line": "Box 4", "page": 1 } },
        { "id": "alien_doc_number", "label": "Alien Registration / USCIS Number, Form I-94, or Foreign Passport Number", "fieldType": "TEXT", "required": false, "order": 16, "sensitive": true,
          "visibleWhen": { "fieldId": "citizenship_status", "equals": "ALIEN_AUTHORIZED" },
          "sourceMapping": { "documentField": "Alien identification number", "section": "Section 1", "line": "Box 4", "page": 1 } },
        { "id": "employee_signature", "label": "Signature of employee", "fieldType": "SIGNATURE", "required": true, "order": 17,
          "validations": [{ "type": "REQUIRED" }],
          "sourceMapping": { "documentField": "Signature of Employee", "section": "Section 1", "page": 1 } },
        { "id": "employee_signature_date", "label": "Today's date", "fieldType": "DATE", "required": true, "order": 18,
          "validations": [{ "type": "DATE" }],
          "sourceMapping": { "documentField": "Today's Date (mm/dd/yyyy)", "section": "Section 1", "page": 1 } }
      ]
    },
