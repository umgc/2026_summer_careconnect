{
  "formType": "I9",
  "title": "Employment Eligibility Verification (Form I-9)",
  "description": "Verifies identity and employment authorization. Section 1 is completed by the employee no later than the first day of work; Section 2 by the employer within three business days.",
  "issuingAuthority": "U.S. Citizenship and Immigration Services (USCIS)",
  "version": "01/20/2025",
